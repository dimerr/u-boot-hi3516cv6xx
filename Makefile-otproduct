# FOR AUDIO
ifeq ($(CONFIG_AUDIO_ENABLE), y)
libs-y += product/audio/ao/
ifeq ($(CONFIG_PRODUCTNAME), $(filter $(CONFIG_PRODUCTNAME), "hi3516cv610" "hi3519dv500" "hi3516dv500"))
libs-y += product/audio/acodec/v751/
endif
endif

ifeq ($(CONFIG_OSD_ENABLE),y)
# FOR DEC of all chip

libs-y += ./product/ot_osd/dec/

ifeq ($(CONFIG_PRODUCTNAME), "hi3519dv500")
libs-y += ./product/ot_osd/vo/
libs-y += ./product/ot_osd/mipi_tx/hi3519dv500/
else
$(warning "warning: "$(CONFIG_PRODUCTNAME)" is invalid")
endif

endif # end of ifeq ($(CONFIG_OSD_ENABLE),y)
